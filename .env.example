# Copia este archivo como `.env` y ajusta los valores.
# El archivo `.env` no se versiona (contiene secretos).

# ── Servidor ───────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── Base de datos (MySQL) ──────────────────────────────────
# DB_HOST: usar `localhost` con el backend local (Fases 1-2);
#          usar `db` cuando el backend corra dentro de Docker (Fase 3).
DB_HOST=localhost
DB_PORT=3306
DB_NAME=web
DB_USER=appuser
DB_PASSWORD=apppassword

# Contraseña del usuario root del contenedor MySQL.
DB_ROOT_PASSWORD=rootpassword

# ── Autenticación JWT ──────────────────────────────────────
JWT_SECRET=reemplaza-esto-por-un-secreto-largo-y-aleatorio
JWT_EXPIRES_IN=5m

# ── CORS ───────────────────────────────────────────────────
CLIENT_URL=http://localhost:3000
